# Скопируй этот файл в .env и заполни значениями

# PostgreSQL connection string
# Render: Internal Database URL из раздела Connect вашей БД
# Neon/Supabase: Connection string из настроек проекта
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Пароль для входа в /admin
ADMIN_PASSWORD=your-admin-password-here

# Секретный ключ для Flask sessions (любая длинная случайная строка)
SECRET_KEY=change-this-to-a-random-secret-key
