# Скопируй этот файл в .env и заполни значениями

# ID таблицы Google Sheets (из URL: /spreadsheets/d/<ID>/edit)
EXPO_PUBLIC_SPREADSHEET_ID=your_spreadsheet_id_here

# API ключ Google (только для чтения, без авторизации)
# Создать: console.cloud.google.com → Credentials → API Key
# Ограничь ключ: Google Sheets API
EXPO_PUBLIC_SHEETS_API_KEY=your_api_key_here

# OAuth 2.0 Client ID (для записи данных)
# Создать: console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Тип: Web application
# Authorized redirect URIs: добавь https://auth.expo.io/@your_expo_username/sborka-app
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
