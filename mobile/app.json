{
  "expo": {
    "name": "СборкаV3",
    "slug": "sborka-v3",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1a73e8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sborka.v3",
      "infoPlist": {
        "NSCameraUsageDescription": "Для сканирования штрихкодов"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a73e8",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.sborka.v3",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        { "cameraPermission": "Для сканирования штрихкодов" }
      ]
    ],
    "extra": {
      "apiUrl": "https://pet-app-sheet.onrender.com"
    }
  }
}
